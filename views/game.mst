<!doctype html>
<html lang="en-GB">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Des frites dans le Slip</title>
    <link rel="icon" type="image/x-icon" href="/images/website/logo.ico">
<!--    <script>document.documentElement.style.visibility = 'hidden'</script>-->
</head>
<body>
{{> partials/defeat}}

<div id="game-page">
    <div id="header" class="row-cols-4">
        <div class="d-flex justify-content-start align-items-center">
            <img id="avatar" src="/images/profiles/{{player.avatar}}" alt="Avatar">
            <h2 id="player-name" class="bagel-font mb-0 px-4">{{player.name}}</h2>
        </div>
        <div id="title-container">
            <h1 id="title" class="bagel-font text-center">Attaque de slips</h1>
            <h4 id="tagline" class="bagel-font text-center">Protège tes frites !</h4>
        </div>
        <div class="d-flex justify-content-end align-items-center">
            <div id="score" class="px-2 bagel-font h4 m-0">{{player.score}}</div>
            <img id="trophy" class="px-2" src="/images/game/trophy.png" alt="Trophy">
        </div>
    </div>
    <div id="game-body">
        <div id="central-container">
            <div id="player-part">
                <div id="fries-plate-container">
                    <img id="fries-plate" src="/images/website/fries.jpg" alt="Plat de frites">
                </div>
                <div id="question" class="h2 m-0">{{title}}</div>
                <div class="w-100 d-flex flex-column justify-content-center align-items-center">
                    <div class="d-flex justify-content-center align-items-center">
                        <div id="guess-inputs-container">
                            {{> partials/guess-inputs}}
                        </div>
                        <button id="guess-button">
                            Vérifier 🚀
                        </button>
                    </div>
                    <div id="lives-container">
                        {{> partials/lives}}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div id="footer">
        <button id="new-question-btn">Nouvelle question</button>
        <button id="logout">Nouveau joueur</button>
    </div>
</div>
<script type="module" src="{{mainScript}}"></script>
</body>
</html>
